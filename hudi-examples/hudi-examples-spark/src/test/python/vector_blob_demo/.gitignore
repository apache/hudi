# Demo runtime artifacts — every run regenerates these. Keep them out of git
# so PRs stay focused on code/docs and reviewers don't see panel PNGs, Spark
# warehouse dirs, or notebook checkpoint JSON in the diff.
outputs/
spark-warehouse/
notebooks/outputs/
notebooks/spark-warehouse/
notebooks/.ipynb_checkpoints/

# venv (some users put it here, some at repo root)
.venv/
