                        </exclusion>
                    </exclusions>
                </dependency>
                <dependency>
                    <groupId>org.apache.hudi</groupId>
                    <artifactId>hudi-java-client</artifactId>
                    <version>${project.version}</version>
                    <scope>test</scope>
                    <exclusions>
                        <exclusion>
                            <groupId>org.apache.hudi</groupId>
                            <artifactId>*</artifactId>
                        </exclusion>
                    </exclusions>
